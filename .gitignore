# dependencies
node_modules/
**/node_modules/

# build artifacts
.next/
**/.next/
dist/
build/
coverage/
*.tsbuildinfo

# environment files (keep examples)
.env
.env.*
!.env.example
!.env.production.example
!env.production.example

# local tooling/cache
.vercel/
.pnpm-store/
.cache/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS files
.DS_Store

# generated temp artifacts
tmp/
apps/web/tmp/
tmp/official-pdfs/
playwright-report/
test-results/

# Claude Code session state (per-worktree settings, transcripts, etc.)
# Should never be committed: it's machine-local and may include local
# user prefs that aren't meaningful in version control.
.claude/
