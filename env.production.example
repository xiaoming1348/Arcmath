# Required
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/arcmath?schema=public"
NEXTAUTH_URL="https://your-company-domain.example.com"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
PASSWORD_PEPPER="replace-with-a-long-random-secret"

# Production recommendation: object storage driver
OFFICIAL_PDF_STORAGE_DRIVER="s3"

# Required when OFFICIAL_PDF_STORAGE_DRIVER="s3"
S3_BUCKET="arcmath-generated-pdfs"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="replace-me"
S3_SECRET_ACCESS_KEY="replace-me"

# Optional S3-compatible overrides
# S3_ENDPOINT="https://s3.amazonaws.com"
# S3_KEY_PREFIX="generated-pdfs"
# S3_FORCE_PATH_STYLE="false"
