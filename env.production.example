# ArcMath production environment template
# Use this as a placeholder-only baseline for Vercel or another hosting platform.

# Database
# Required. Production Postgres / Neon connection string.
DATABASE_URL="postgresql://neondb_owner:npg_2xvZpkjycEB0@ep-snowy-feather-aitap2lv-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Auth
# Required. Public base URL for NextAuth callbacks and absolute links.
NEXTAUTH_URL="https://arcscience.forecaster-ai.com"
# Required. Secret used to sign/encrypt NextAuth JWT cookies.
NEXTAUTH_SECRET="Q3Q3rCdD2vbfHWp4HBEMj93YDOAQmovP8vuPKHv4cuEmgz/68BxmxLC3h/XBZreQ"

# Password / crypto
# Required. Password hashes are created/verified as password + pepper.
PASSWORD_PEPPER="replace-with-a-long-random-secret"

# OpenAI / tutor
# Required only if production should use real AI-generated tutor responses.
OPENAI_API_KEY=""
# Optional model override.
# OPENAI_MODEL="gpt-4.1-mini"
# Optional full Responses API endpoint override.
# OPENAI_BASE_URL="https://api.openai.com/v1/responses"

# PDF / storage
# Required. Production recommendation is `s3`.
OFFICIAL_PDF_STORAGE_DRIVER="s3"

# S3 / object storage
# Required when OFFICIAL_PDF_STORAGE_DRIVER="s3".
S3_BUCKET="replace-with-bucket-name"
S3_REGION="replace-with-region"
S3_ACCESS_KEY_ID="replace-with-access-key-id"
S3_SECRET_ACCESS_KEY="replace-with-secret-access-key"

# Optional S3-compatible overrides.
# S3_ENDPOINT="https://s3.amazonaws.com"
# S3_KEY_PREFIX="official-pdfs"
# S3_FORCE_PATH_STYLE="false"

# Optional local-driver cache override.
# Normally not used in production.
# OFFICIAL_PDF_CACHE_DIR="/absolute/path/to/official-pdf-cache"
