# ArcMath local database template
# Copy to `.env` when you want to run against a local Postgres instance.
# This file is primarily used by `pnpm dev:local` and the `db:*` scripts.

# Database
# Required for local Postgres / Docker development.
# Docker Compose in this repo maps host 5433 -> container 5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/arcmath?schema=public"

# Auth
# Required for NextAuth callback URLs in local browser sessions.
NEXTAUTH_URL="http://localhost:3000"
# Required for signing/encrypting NextAuth JWT cookies.
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Password / crypto
# Required because password hashes are created/verified as password + pepper.
PASSWORD_PEPPER="replace-with-a-long-random-secret"

# PDF / storage
# Required for official PDF storage selection.
# Use `local` for local development unless you explicitly want S3 testing.
OFFICIAL_PDF_STORAGE_DRIVER="local"
# Optional local cache override. Defaults to `<repo>/tmp/official-pdfs`.
# OFFICIAL_PDF_CACHE_DIR="tmp/official-pdfs"

# OpenAI / tutor
# Optional. Required only if you want real AI-generated hints/explanations locally.
# If omitted, the app falls back to safe local placeholder tutor responses.
# OPENAI_API_KEY="replace-with-openai-api-key"
# Optional model override.
# OPENAI_MODEL="gpt-4.1-mini"
# Optional full Responses API endpoint override.
# OPENAI_BASE_URL="https://api.openai.com/v1/responses"

# Optional S3 settings
# Required only when OFFICIAL_PDF_STORAGE_DRIVER="s3".
# S3_BUCKET="replace-with-bucket-name"
# S3_REGION="replace-with-region"
# S3_ACCESS_KEY_ID="replace-with-access-key-id"
# S3_SECRET_ACCESS_KEY="replace-with-secret-access-key"
# Optional S3-compatible overrides.
# S3_ENDPOINT="https://s3.amazonaws.com"
# S3_KEY_PREFIX="official-pdfs"
# S3_FORCE_PATH_STYLE="false"
