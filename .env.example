# Canonical Docker DB URL (docker-compose maps host 5433 -> container 5432)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/arcmath?schema=public"
# Optional local DB alternative (if not using Docker):
# DATABASE_URL="postgresql://<user>:<password>@localhost:5432/arcmath?schema=public"
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
PASSWORD_PEPPER=""
# Optional: override official PDF local cache directory (default: <repo>/tmp/official-pdfs)
# Local filesystem cache is recommended for development only.
# OFFICIAL_PDF_CACHE_DIR="tmp/official-pdfs"

# Storage driver: local (development) or s3 (production recommendation)
OFFICIAL_PDF_STORAGE_DRIVER="local"

# S3-compatible storage config (required when OFFICIAL_PDF_STORAGE_DRIVER="s3")
# S3_BUCKET="arcmath-official-pdfs"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# Optional S3-compatible settings
# S3_ENDPOINT=""
# S3_KEY_PREFIX="official-pdfs"
# S3_FORCE_PATH_STYLE="false"
