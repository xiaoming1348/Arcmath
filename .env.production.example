# Neon Postgres (required)
# Add sslmode=require for Neon pooled/direct URL.
DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require"

# NextAuth (required)
NEXTAUTH_URL="https://<your-production-domain>"
NEXTAUTH_SECRET="<long-random-secret>"

# Password hardening (required)
PASSWORD_PEPPER="<long-random-secret>"

# Storage driver (required)
# Production recommendation: s3
OFFICIAL_PDF_STORAGE_DRIVER="s3"

# S3-compatible object storage (required when OFFICIAL_PDF_STORAGE_DRIVER=s3)
S3_BUCKET="<bucket-name>"
S3_REGION="<region>"
S3_ACCESS_KEY_ID="<access-key-id>"
S3_SECRET_ACCESS_KEY="<secret-access-key>"

# Optional S3-compatible overrides
# S3_ENDPOINT="https://s3.amazonaws.com"
# S3_KEY_PREFIX="official-pdfs"
# S3_FORCE_PATH_STYLE="false"

# Optional only when temporarily using local storage driver in non-standard setups
# OFFICIAL_PDF_CACHE_DIR="/absolute/path/to/cache"
